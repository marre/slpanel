{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "slpanel",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-27",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "slpanel",
      "database_id": "31ad8d02-c706-487e-bd5d-a7a94bf325ec",
    },
  ],
}
